#!/usr/bin/env bash

set -euo pipefail

PROJECT_DIR="workspace/demo_project"
LOCAL_FILE="/absolute/path/to/downloaded/hero.jpg"

python3 skills/slidemax_workflow/commands/register_stock_image.py \
  "$PROJECT_DIR" \
  --provider unsplash \
  --source-url "https://unsplash.com/photos/example-id" \
  --local-file "$LOCAL_FILE" \
  --filename hero_cover.jpg \
  --creator-name "Photographer Name" \
  --creator-url "https://unsplash.com/@creator" \
  --keywords "hero, office, business"
