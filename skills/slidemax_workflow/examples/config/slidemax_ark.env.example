# SlideMax ARK video generation configuration example
# Copy this file to a local untracked path such as:
#   cp skills/slidemax_workflow/examples/config/slidemax_ark.env.example .env.slidemax-ark
# Then load it before running ARK task commands:
#   source .env.slidemax-ark
# If you want AI help, paste this into your assistant after copying this file:
#   I am setting up SlideMax ARK video generation.
#   Please tell me which variables are required, which defaults are safe to keep,
#   and how to verify the setup before I create a live task.


# Required credential.
ARK_API_KEY=replace-with-your-ark-key

# Optional base URL override.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Optional HTTP timeout.
ARK_TIMEOUT=180

# Optional default model override for doubao_i2v_task.py.
ARK_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
