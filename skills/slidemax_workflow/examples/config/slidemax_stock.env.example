# SlideMax stock image sourcing configuration example
# Copy this file to an untracked path such as:
#   cp skills/slidemax_workflow/examples/config/slidemax_stock.env.example .env.slidemax-stock
# Then load it before running stock registration commands:
#   source .env.slidemax-stock

# Root directory for stock assets relative to the project directory.
SLIDEMAX_STOCK_ROOT_DIR=images/stock

# Optional provider allowlist for local team conventions.
SLIDEMAX_STOCK_ALLOWED_PROVIDERS=unsplash,pexels,pixabay

# Reminder-only setting for internal reviews.
SLIDEMAX_STOCK_REQUIRE_LICENSE=true
