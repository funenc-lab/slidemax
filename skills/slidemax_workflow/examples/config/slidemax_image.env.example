# SlideMax image generation configuration example
# Copy this file to a local untracked path such as:
#   cp skills/slidemax_workflow/examples/config/slidemax_image.env.example .env.slidemax-image
# Then load it before running image generation commands:
#   source .env.slidemax-image
# If you want AI help, paste this into your assistant after copying this file:
#   I am setting up SlideMax image generation.
#   Please help me fill this env file for my chosen provider, explain the required variables,
#   and tell me which doctor command to run next using the canonical docs under skills/slidemax_workflow/docs/.

# Validate the active provider before first use:
#   python3 skills/slidemax_workflow/commands/project_manager.py doctor --provider gemini
#   python3 skills/slidemax_workflow/commands/project_manager.py doctor --provider doubao --model doubao-seedream-5

# ------------------------------------------------------------
# Shared defaults
# ------------------------------------------------------------

# Default provider when --provider is omitted.
SLIDEMAX_IMAGE_PROVIDER=gemini

# Default output directory for generated images.
SLIDEMAX_IMAGE_OUTPUT_DIR=workspace/demo/images

# Optional request timeout in seconds for SDK calls and response downloads.
SLIDEMAX_IMAGE_TIMEOUT=180

# Optional shared overrides. Leave empty unless you want one set of
# credentials to apply to every provider.
# SLIDEMAX_IMAGE_API_KEY=
# SLIDEMAX_IMAGE_BASE_URL=
# SLIDEMAX_IMAGE_ENDPOINT=
# SLIDEMAX_IMAGE_MODEL=


# ------------------------------------------------------------
# Gemini provider
# ------------------------------------------------------------

# Required for provider=gemini.
GEMINI_API_KEY=replace-with-your-gemini-key

# Optional proxy or gateway.
# GEMINI_BASE_URL=https://your-gemini-gateway.example

# Optional model override.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview


# ------------------------------------------------------------
# OpenAI-compatible provider
# ------------------------------------------------------------

# Required for provider=openai-compatible.
# OPENAI_IMAGE_API_KEY=replace-with-your-openai-compatible-key

# Base URL is required for SDK-based providers.
# OPENAI_IMAGE_BASE_URL=https://your-openai-compatible-gateway.example/v1
# OPENAI_IMAGE_ENDPOINT=https://your-openai-compatible-gateway.example/v1/images/generations

# Optional model override.
# OPENAI_IMAGE_MODEL=gpt-image-1


# ------------------------------------------------------------
# Doubao provider
# ------------------------------------------------------------

# Required for provider=doubao. Prefer the official ARK variable names.
# ARK_API_KEY=replace-with-your-ark-key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Workflow aliases are also accepted.
# DOUBAO_API_KEY=replace-with-your-doubao-key
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Optional explicit endpoint override for non-standard gateways only.
# DOUBAO_IMAGE_ENDPOINT=https://your-doubao-gateway.example/v1/images/generations

# Optional model override for static image generation.
DOUBAO_IMAGE_MODEL=doubao-seedream-4.5
# Alternative static image model:
# DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
# Seedance video workflows should use commands/doubao_i2v_task.py instead.
