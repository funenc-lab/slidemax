# PPT Master image generation configuration example
# Copy this file to a local untracked path such as:
#   cp skills/ppt_master_workflow/examples/config/pptmaster_image.env.example .env.pptmaster-image
# Then load it before running image generation commands:
#   source .env.pptmaster-image

# ------------------------------------------------------------
# Shared defaults
# ------------------------------------------------------------

# Default provider when --provider is omitted.
PPTMASTER_IMAGE_PROVIDER=gemini

# Default output directory for generated images.
PPTMASTER_IMAGE_OUTPUT_DIR=workspace/demo/images

# Optional timeout for HTTP-based providers.
PPTMASTER_IMAGE_TIMEOUT=180

# Optional shared overrides. Leave empty unless you want one set of
# credentials to apply to every provider.
# PPTMASTER_IMAGE_API_KEY=
# PPTMASTER_IMAGE_BASE_URL=
# PPTMASTER_IMAGE_ENDPOINT=
# PPTMASTER_IMAGE_MODEL=


# ------------------------------------------------------------
# Gemini provider
# ------------------------------------------------------------

# Required for provider=gemini.
GEMINI_API_KEY=replace-with-your-gemini-key

# Optional proxy or gateway.
# GEMINI_BASE_URL=https://your-gemini-gateway.example

# Optional model override.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview


# ------------------------------------------------------------
# OpenAI-compatible provider
# ------------------------------------------------------------

# Required for provider=openai-compatible.
# OPENAI_IMAGE_API_KEY=replace-with-your-openai-compatible-key

# Base URL is required for SDK-based providers.
# OPENAI_IMAGE_BASE_URL=https://your-openai-compatible-gateway.example/v1
# OPENAI_IMAGE_ENDPOINT=https://your-openai-compatible-gateway.example/v1/images/generations

# Optional model override.
# OPENAI_IMAGE_MODEL=gpt-image-1


# ------------------------------------------------------------
# Doubao provider
# ------------------------------------------------------------

# Required for provider=doubao.
# DOUBAO_API_KEY=replace-with-your-doubao-key

# Base URL is required for SDK-based providers.
# DOUBAO_BASE_URL=https://your-doubao-gateway.example/v1
# DOUBAO_IMAGE_ENDPOINT=https://your-doubao-gateway.example/v1/images/generations

# Optional model override for static image generation.
DOUBAO_IMAGE_MODEL=doubao-seedream-4.5
# Alternative static image model:
# DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
# Seedance video workflows should use commands/doubao_i2v_task.py instead.
