# PPT Master ARK video generation configuration example
# Copy this file to a local untracked path such as:
#   cp skills/ppt_master_workflow/examples/config/pptmaster_ark.env.example .env.pptmaster-ark
# Then load it before running ARK task commands:
#   source .env.pptmaster-ark

# Required credential.
ARK_API_KEY=replace-with-your-ark-key

# Optional base URL override.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Optional HTTP timeout.
ARK_TIMEOUT=180

# Optional default model override for doubao_i2v_task.py.
ARK_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
