# PPT Master stock image sourcing configuration example
# Copy this file to an untracked path such as:
#   cp skills/ppt_master_workflow/examples/config/pptmaster_stock.env.example .env.pptmaster-stock
# Then load it before running stock registration commands:
#   source .env.pptmaster-stock

# Root directory for stock assets relative to the project directory.
PPTMASTER_STOCK_ROOT_DIR=images/stock

# Optional provider allowlist for local team conventions.
PPTMASTER_STOCK_ALLOWED_PROVIDERS=unsplash,pexels,pixabay

# Reminder-only setting for internal reviews.
PPTMASTER_STOCK_REQUIRE_LICENSE=true
